<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F8">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Calendar Misiuni"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1565C0"
        android:padding="16dp"
        android:background="@android:color/white" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@android:color/white"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <Button
            android:id="@+id/btnLunaPrecedenta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&lt;"
            android:textSize="18sp"
            style="?android:attr/borderlessButtonStyle" />

        <TextView
            android:id="@+id/tvLunaAn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1565C0" />

        <Button
            android:id="@+id/btnLunaUrmatoare"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&gt;"
            android:textSize="18sp"
            style="?android:attr/borderlessButtonStyle" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#E3F2FD"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center" android:text="L"
            android:textStyle="bold" android:textColor="#1565C0" android:textSize="12sp" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center" android:text="M"
            android:textStyle="bold" android:textColor="#1565C0" android:textSize="12sp" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center" android:text="M"
            android:textStyle="bold" android:textColor="#1565C0" android:textSize="12sp" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center" android:text="J"
            android:textStyle="bold" android:textColor="#1565C0" android:textSize="12sp" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center" android:text="V"
            android:textStyle="bold" android:textColor="#1565C0" android:textSize="12sp" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center" android:text="S"
            android:textStyle="bold" android:textColor="#E53935" android:textSize="12sp" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center" android:text="D"
            android:textStyle="bold" android:textColor="#E53935" android:textSize="12sp" />
    </LinearLayout>

    <GridView
        android:id="@+id/gridCalendar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:numColumns="7"
        android:background="@android:color/white"
        android:stretchMode="columnWidth" />

    <TextView
        android:id="@+id/tvZiSelectata"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Selectati o data din calendar"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#37474F"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="4dp" />

    <ListView
        android:id="@+id/lvMisiuniZi"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#CFD8DC"
        android:dividerHeight="1dp" />

</LinearLayout>
