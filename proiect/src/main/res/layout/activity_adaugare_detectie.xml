<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/titlu_adaugare"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1565C0"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_camera"
            android:textSize="13sp"
            android:textColor="#546E7A" />

        <Spinner
            android:id="@+id/spinnerCamera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_locatie"
            android:textSize="13sp"
            android:textColor="#546E7A" />

        <EditText
            android:id="@+id/etLocatie"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_locatie"
            android:inputType="text"
            android:background="@android:color/white"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_persoane"
            android:textSize="13sp"
            android:textColor="#546E7A" />

        <EditText
            android:id="@+id/etPersoane"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_persoane"
            android:inputType="number"
            android:background="@android:color/white"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnSelecteazaData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_selecteaza_data"
            android:backgroundTint="#546E7A"
            android:textColor="@android:color/white"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvDataSelectata"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/data_neselectata"
            android:textSize="14sp"
            android:gravity="center"
            android:textColor="#78909C"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_confidenta"
            android:textSize="13sp"
            android:textColor="#546E7A" />

        <RatingBar
            android:id="@+id/ratingBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:rating="3"
            android:stepSize="1"
            android:layout_marginBottom="16dp" />

        <CheckBox
            android:id="@+id/cbAlerta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_alerta"
            android:textColor="#37474F"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_activ"
                android:textSize="14sp"
                android:textColor="#37474F" />

            <Switch
                android:id="@+id/swActiv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:visibility="gone"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnSalveazaDetectie"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_salveaza"
            android:backgroundTint="#1565C0"
            android:textColor="@android:color/white" />

    </LinearLayout>
</ScrollView>
