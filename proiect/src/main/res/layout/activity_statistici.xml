<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F8"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/titlu_statistici"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1565C0"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvTotalDetectii"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Total detectii: 0"
        android:textSize="16sp"
        android:textColor="#37474F"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvTotalPersoane"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Total persoane detectate: 0"
        android:textSize="16sp"
        android:textColor="#37474F"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvTotalAlerte"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Total alerte: 0"
        android:textSize="16sp"
        android:textColor="#C62828"
        android:layout_marginBottom="16dp" />

    <com.example.proiect.StatisticiView
        android:id="@+id/graficDetectii"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@android:color/white" />

</LinearLayout>
