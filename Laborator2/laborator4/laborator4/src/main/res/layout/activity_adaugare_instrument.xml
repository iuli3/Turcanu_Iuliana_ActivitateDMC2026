<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvTitlu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/titlu_adauga"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_nume"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etNume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_nume"
            android:inputType="textCapSentences"
            android:autofillHints="name"
            android:background="@android:color/white"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_an"
            android:textColor="#333333"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etAnFabricatie"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_an"
            android:inputType="number"
            android:autofillHints="no"
            android:background="@android:color/white"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_pret"
            android:textColor="#333333"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etPret"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_pret"
            android:inputType="numberDecimal"
            android:autofillHints="no"
            android:background="@android:color/white"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <CheckBox
            android:id="@+id/cbDisponibil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_disponibil"
            android:textSize="15sp"
            android:textColor="#333333"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_tip_sunet"
            android:textColor="#333333"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>

        <RadioGroup
            android:id="@+id/rgTipSunet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/rbAcustic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rb_acustic"
                android:checked="true"
                android:layout_marginEnd="24dp"/>

            <RadioButton
                android:id="@+id/rbElectric"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rb_electric"/>

        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_categorie"
            android:textColor="#333333"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>

        <Spinner
            android:id="@+id/spinnerCategorie"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:padding="9dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_rating"
            android:textColor="#333333"
            android:textSize="15sp"
            android:layout_marginBottom="4dp"/>

        <RatingBar
            android:id="@+id/ratingBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:rating="3"
            android:stepSize="0.5"
            android:layout_marginBottom="17dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_oferta"
            android:textColor="#333333"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchOferta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/switch_oferta"
            android:textSize="14sp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_vanzare"
            android:textColor="#333333"
            android:textSize="16sp"
            android:layout_marginBottom="4dp"/>

        <ToggleButton
            android:id="@+id/toggleVanzare"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textOn="@string/toggle_activ"
            android:textOff="@string/toggle_inactiv"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btnSalveaza"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_salveaza"
            android:textSize="15sp"
            android:backgroundTint="#1A237E"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>